{
  "@context": {
    "@version": 1.1,
    "core": "https://ontology.levinci.dev/core/",
    "sw": "https://ontology.levinci.dev/sw/",
    "vibe": "https://ontology.levinci.dev/vibe/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "label": "rdfs:label",
    "comment": "rdfs:comment",
    "subClassOf": { "@id": "rdfs:subClassOf", "@type": "@id" },
    "subPropertyOf": { "@id": "rdfs:subPropertyOf", "@type": "@id" },
    "domain": { "@id": "rdfs:domain", "@type": "@id" },
    "range": { "@id": "rdfs:range", "@type": "@id" },
    "owl:imports": { "@id": "owl:imports", "@type": "@id" },
    "owl:versionInfo": { "@id": "owl:versionInfo", "@type": "xsd:string" },
    "identifier": { "@id": "core:identifier", "@type": "xsd:string" },
    "slug": { "@id": "core:slug", "@type": "xsd:string" },
    "name": { "@id": "core:name", "@type": "xsd:string" },
    "description": { "@id": "core:description", "@type": "xsd:string" },
    "createdAt": { "@id": "core:createdAt", "@type": "xsd:dateTime" },
    "updatedAt": { "@id": "core:updatedAt", "@type": "xsd:dateTime" },
    "sourceUri": { "@id": "core:sourceUri", "@type": "xsd:anyURI" },
    "confidence": { "@id": "core:confidence", "@type": "xsd:decimal" },
    "status": { "@id": "core:status", "@type": "xsd:string" },
    "belongsToProject": { "@id": "core:belongsToProject", "@type": "@id" },
    "relatesTo": { "@id": "core:relatesTo", "@type": "@id" },
    "partOf": { "@id": "core:partOf", "@type": "@id" },
    "mentions": { "@id": "core:mentions", "@type": "@id" },
    "createdBy": { "@id": "core:createdBy", "@type": "@id" },
    "instanceOf": { "@id": "core:instanceOf", "@type": "@id" },
    "derivedFrom": { "@id": "core:derivedFrom", "@type": "@id" },
    "broader": { "@id": "skos:broader", "@type": "@id" },
    "narrower": { "@id": "skos:narrower", "@type": "@id" },
    "about": { "@id": "core:about", "@type": "@id" },
    "assertedBy": { "@id": "core:assertedBy", "@type": "@id" },
    "contains": { "@id": "sw:contains", "@type": "@id" },
    "dependsOn": { "@id": "sw:dependsOn", "@type": "@id" },
    "definedIn": { "@id": "sw:definedIn", "@type": "@id" },
    "implements": { "@id": "sw:implements", "@type": "@id" },
    "path": { "@id": "sw:path", "@type": "xsd:string" },
    "language": { "@id": "sw:language", "@type": "xsd:string" },
    "repositoryUrl": { "@id": "sw:repositoryUrl", "@type": "xsd:anyURI" },
    "producedInSession": { "@id": "vibe:producedInSession", "@type": "@id" },
    "implementsIntent": { "@id": "vibe:implementsIntent", "@type": "@id" },
    "revises": { "@id": "vibe:revises", "@type": "@id" },
    "promptedBy": { "@id": "vibe:promptedBy", "@type": "@id" },
    "turnIndex": { "@id": "vibe:turnIndex", "@type": "xsd:integer" },
    "role": { "@id": "vibe:role", "@type": "xsd:string" },
    "content": { "@id": "vibe:content", "@type": "xsd:string" }
  }
}
