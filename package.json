{
  "name": "semantic-graph-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "docker:up": "docker compose -f database/docker-compose.yml up -d",
    "docker:down": "docker compose -f database/docker-compose.yml down",
    "docker:logs": "docker compose -f database/docker-compose.yml logs -f",
    "graph:export": "tsx src/ontology/export-graph.ts",
    "db:seed": "bash database/seed-all.sh",
    "db:migrate": "bash database/seed-one.sh",
    "api:example": "node example-api/server.mjs",
    "api:example:watch": "node --watch example-api/server.mjs"
  },
  "dependencies": {
    "express": "^4.22.2",
    "neo4j-driver": "^5.28.1",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
